{
  "name": "papo",
  "version": "0.4.10",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch src/server/index.ts",
    "serve:api": "tsx src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "build:papo": "VITE_BASE_PATH=/papo/ VITE_API_BASE=/papo-api npm run build",
    "build:android:web": "VITE_BASE_PATH=/ VITE_API_BASE=https://eu.jerrypsy.top/papo-api npm run build",
    "android:sync": "npm run build:android:web && cap sync android",
    "android:assets": "bash scripts/generate-android-assets.sh",
    "android:doctor": "bash scripts/android-doctor.sh",
    "apk:debug": "npm run android:sync && cd android && ./gradlew assembleDebug && cd .. && mkdir -p artifacts && cp android/app/build/outputs/apk/debug/app-debug.apk artifacts/papo-debug.apk",
    "apk:release": "bash scripts/build-android-release.sh",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --test --import tsx tests/*.test.ts",
    "test:ui": "playwright test",
    "smoke:real-cognition": "RUN_REAL_MODEL_SMOKE=1 tsx tests/real-cognition-smoke.ts",
    "migrate:papo-memories": "tsx scripts/migrate-papo-memory-experience.ts papo",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "discord.js": "^14.26.4",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "react-photo-view": "^1.2.7",
    "tsx": "^4.19.2",
    "vite": "^6.0.7",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2"
  }
}
